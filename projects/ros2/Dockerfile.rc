# Dockerfile.rc
FROM bfrzn/ros2-base:jazzy

# Install Python serial and build tools
RUN apt-get update && apt-get install -y \
    python3-serial \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install CRSF parser library
RUN pip3 install crsf-parser --break-system-packages

# Set up RC workspace
WORKDIR /rc_ws
RUN mkdir -p src

RUN echo "source /opt/ros/jazzy/setup.bash" >> ~/.bashrc