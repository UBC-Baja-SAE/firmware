master:
  node_id: 127
  driver: "ros2_canopen::MasterDriver"
  package: "canopen_master_driver"
  baudrate: 500000
  boot_timeout: 20000

rear_ecu:
  node_id: 5
  driver: "ros2_canopen::ProxyDriver"
  package: "canopen_proxy_driver"
  dcf: "/ros_ws/canopen/rear_ecu.dcf"
  polling: true
  period: 10
  boot_timeout: 15000
  sdo_timeout: 5000